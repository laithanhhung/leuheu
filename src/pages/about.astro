---
import Layout from '../layouts/Layout.astro';

const pageTitle = "About Astro";
const author = "Astro Developer";
const currentYear = new Date().getFullYear();

// Define some data
const features = [
  "Server-side rendering",
  "Static site generation",
  "Component-based architecture",
  "Markdown support",
  "CSS scoping"
];
---

<Layout>
  <div class="about-container">
    <h1>{pageTitle}</h1>

    <p>Welcome to our Astro site! This page demonstrates the power of Astro's .astro syntax.</p>

    <section class="features">
      <h2>Key Features</h2>
      <ul>
        {features.map(feature => <li>{feature}</li>)}
      </ul>
    </section>

    <section class="info">
      <p>Built with ❤️ using Astro {Astro.generator}</p>
      <p>© {currentYear} {author}</p>
    </section>
  </div>
</Layout>

<style>
  .about-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  h1 {
    color: #2d3748;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .about-container > p {
    font-size: 1.2rem;
    color: #4a5568;
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .features {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 2rem;
    border-radius: 12px;
    margin: 2rem 0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .features h2 {
    margin-top: 0;
    font-size: 1.8rem;
    text-align: center;
  }

  .features ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 0 0;
  }

  .features li {
    background: rgba(255, 255, 255, 0.1);
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .info {
    text-align: center;
    margin-top: 3rem;
    padding: 1.5rem;
    background: #f7fafc;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  .info p {
    margin: 0.5rem 0;
    color: #4a5568;
  }

  @media (max-width: 768px) {
    .about-container {
      padding: 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .features {
      padding: 1.5rem;
    }

    .features ul {
      grid-template-columns: 1fr;
    }
  }
</style>
